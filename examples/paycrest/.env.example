PAYCREST_API_KEY=your_paycrest_api_key_here
RPC_URL=https://api.cartridge.gg/x/starknet/mainnet
PRIVATE_KEY=0x...
WALLET_ADDRESS=0x...

# Stablecoin to off-/on-ramp. USDC or USDT. Defaults to USDT.
PAYCREST_TOKEN=USDT

# Optional AVNU paymaster API key. When set, the off-ramp examples
# (offramp-api.ts and offramp-gateway.ts) sponsor the on-chain leg via
# AVNU's paymaster — the wallet pays no STRK gas. Unset for the SDK's
# default `user_pays` mode.
AVNU_PAYMASTER_API_KEY=

# Optional gas token within sponsored mode: USDT | USDC | STRK | ETH.
# Leave empty for fully sponsored (paymaster covers all gas). Requires
# AVNU_PAYMASTER_API_KEY to be set — otherwise the example errors.
PAYCREST_GAS_TOKEN=

# Recipient bank account (NGN example via GTB)
RECIPIENT_INSTITUTION=GTBINGLA
RECIPIENT_ACCOUNT_IDENTIFIER=0123456789
RECIPIENT_ACCOUNT_NAME=John Doe
