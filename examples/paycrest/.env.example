PAYCREST_API_KEY=your_paycrest_api_key_here
RPC_URL=https://starknet-mainnet.public.blastapi.io
PRIVATE_KEY=0x...
WALLET_ADDRESS=0x...

# Stablecoin to off-/on-ramp. USDC or USDT. Defaults to USDT.
PAYCREST_TOKEN=USDT

# Optional gas token for the sponsored example: USDT | USDC | STRK | ETH.
# Leave empty for fully sponsored paymaster mode (no gas paid by the user).
PAYCREST_GAS_TOKEN=

# Optional AVNU paymaster API key. Required for fully sponsored mode
# (fee_mode: sponsored) on AVNU's public paymaster endpoint. Not needed
# when paying gas in a token via PAYCREST_GAS_TOKEN.
AVNU_PAYMASTER_API_KEY=

# Recipient bank account (NGN example via GTB)
RECIPIENT_INSTITUTION=GTBINGLA
RECIPIENT_ACCOUNT_IDENTIFIER=0123456789
RECIPIENT_ACCOUNT_NAME=John Doe
