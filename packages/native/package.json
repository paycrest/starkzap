{
  "name": "starkzap-native",
  "version": "3.0.0",
  "description": "React Native companion package for Starkzap",
  "homepage": "https://github.com/keep-starknet-strange/starkzap/tree/main/packages/native#readme",
  "bugs": {
    "url": "https://github.com/keep-starknet-strange/starkzap/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/keep-starknet-strange/starkzap.git",
    "directory": "packages/native"
  },
  "license": "MIT",
  "author": "0xLucqs",
  "type": "module",
  "source": "./src/index.ts",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./metro": {
      "require": "./metro.cjs"
    }
  },
  "files": [
    "dist",
    "metro.cjs"
  ],
  "sideEffects": [
    "./dist/polyfills/install.js"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "npm run build --prefix ../.. && tsc && tsc-alias",
    "typecheck": "npm run build --prefix ../.. && tsc --noEmit",
    "test": "npm run build --prefix ../.. && vitest run --config vitest.config.mjs",
    "test:cartridge:parity": "npm run build --prefix ../.. && vitest run --config vitest.config.mjs tests/cartridge/parity.unit.test.ts"
  },
  "dependencies": {
    "expo": "^55.0.8",
    "starkzap": "^3.0.0"
  },
  "peerDependencies": {
    "@ethersproject/shims": "^5.7.0",
    "buffer": "^6.0.3",
    "fast-text-encoding": "^1.0.6",
    "react-native-get-random-values": "^1.11.0"
  }
}
